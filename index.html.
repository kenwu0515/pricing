<style>
  .qty-btn {
    padding: 6px 16px; border-radius: 20px; border: 1.5px solid #e8e6e1;
    background: #fff; font-size: 12px; font-weight: 500; cursor: pointer;
    font-family: inherit; color: #888; transition: all 0.15s;
  }
  .qty-btn.active { border-color: #1a1a1a; background: #1a1a1a; color: #fff; }
  .qty-btn:hover:not(.active) { border-color: #bbb; }
</style>

<script>
  const state = {
    eq: 'phone',
    scope: 'full',
    qty: '4',
    termValues: {
      'phone-full-4': { val: 'monthly', base: 24000, label: '月繳 · 4 支', unit: '每月' },
      'phone-full-8': { val: 'monthly8', base: 46400, label: '月繳 · 8 支以上', unit: '每月' },
      'camera-full':  { val: 'cam-full-3', base: 45000, label: '3 支', unit: '總計參考' },
      'camera-shoot': { val: 'cam-shoot-3', base: 30000, label: '3 支', unit: '總計參考' },
    },
    addons: 0,
    addonNames: []
  };

  function currentPanel() {
    if (state.eq === 'phone') return 'phone-full-' + state.qty;
    return 'camera-' + state.scope;
  }

  function showPanel(id) {
    document.querySelectorAll('.term-panel').forEach(p => p.classList.remove('active'));
    const el = document.getElementById('panel-' + id);
    if (el) { el.classList.add('active'); void el.offsetWidth; el.classList.add('panel-fade'); }
  }

  function pickEq(el) {
    document.querySelectorAll('#eq .opt').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    state.eq = el.dataset.val;

    const shootOpt = document.getElementById('scope-shoot');
    const phoneNote = document.getElementById('phone-shoot-note');

    if (state.eq === 'phone') {
      // 手機：強制回到全案代操
      state.scope = 'full';
      document.querySelectorAll('#scope .opt').forEach(c => c.classList.remove('selected'));
      document.querySelector('#scope .opt[data-val="full"]').classList.add('selected');
      shootOpt.classList.add('disabled');
      phoneNote.classList.add('show');
    } else {
      shootOpt.classList.remove('disabled');
      phoneNote.classList.remove('show');
    }

    showPanel(currentPanel());
    render();
  }

  function pickScope(el) {
    if (el.classList.contains('disabled')) return;
    document.querySelectorAll('#scope .opt').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    state.scope = el.dataset.val;
    showPanel(currentPanel());
    render();
  }

  function switchQty(q) {
    state.qty = q;
    showPanel(currentPanel());
    render();
  }

  function pickTerm(el, panelKey) {
    const gridId = 'term-' + panelKey.replace('phone-full-', 'phone-').replace('camera-', 'camera-');
    // 找到正確的 grid
    const panel = document.getElementById('panel-' + panelKey);
    panel.querySelectorAll('.opt').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');

    const trialNote = document.getElementById('trial-note');
    if (trialNote) trialNote.classList.toggle('show', el.dataset.val === 'trial');

    const termLabels = {
      trial: '試拍單支', monthly: '月繳 · 4 支', '3m': '簽約 3 個月 · 4 支',
      '6m': '簽約半年 · 4 支', monthly8: '月繳 · 8 支以上', '3m8': '簽約 3 個月 · 8 支以上',
      '6m8': '簽約半年 · 8 支以上', 'cam-full-3': '全案代操 · 3 支',
      'cam-full-6': '全案代操 · 6 支', 'cam-shoot-3': '拍攝執行 · 3 支',
      'cam-shoot-6': '拍攝執行 · 6 支'
    };
    const termUnits = {
      trial: '單次', monthly: '每月', '3m': '每月', '6m': '每月',
      monthly8: '每月', '3m8': '每月', '6m8': '每月',
      'cam-full-3': '總計參考', 'cam-full-6': '總計參考',
      'cam-shoot-3': '總計參考', 'cam-shoot-6': '總計參考'
    };

    state.termValues[panelKey] = {
      val: el.dataset.val,
      base: parseInt(el.dataset.base),
      label: termLabels[el.dataset.val] || el.dataset.val,
      unit: termUnits[el.dataset.val] || ''
    };
    render();
  }

  function toggleAddon(el) {
    const price = parseInt(el.dataset.price);
    const name = el.dataset.name;
    el.classList.toggle('selected');
    if (el.classList.contains('selected')) {
      state.addons += price; state.addonNames.push(name);
    } else {
      state.addons -= price;
      state.addonNames = state.addonNames.filter(n => n !== name);
    }
    render();
  }

  function render() {
    const eqLabel = { phone: '手機拍攝', camera: '相機拍攝' };
    const scopeLabel = { full: '全案代操', shoot: '拍攝執行' };
    document.getElementById('s-eq').textContent = eqLabel[state.eq];
    document.getElementById('s-scope').textContent = scopeLabel[state.scope];

    const panel = currentPanel();
    const tv = state.termValues[panel];
    document.getElementById('s-term').textContent = tv ? tv.label : '—';
    document.getElementById('s-unit').textContent = tv ? tv.unit + ' · ' : '';

    document.getElementById('s-addon').textContent = state.addonNames.length ? state.addonNames.join('、') : '—';
    const base = tv ? tv.base : 0;
    document.getElementById('s-total').textContent = 'NT$' + (base + state.addons).toLocaleString();
  }

  render();
</script>
</body>
</html>
